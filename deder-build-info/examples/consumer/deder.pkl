amends "https://sake92.github.io/deder/config/v0.17.0/DederProject.pkl"

import "../../resources/BuildInfoPlugin.pkl" as BI

plugins {
  new BI.BuildInfoPlugin {
    config = new {
      defaults = new {
        packageName = "consumer"
        includeGitHash = true
        includeTimestamp = true
      }
    }
  }
}

modules {
  new ScalaModule {
    id = "example"
    root = "."
    scalaVersion = "3.7.4"
    mainClass = "consumer.main"
  }
}
