amends "https://sake92.github.io/deder/config/v0.17.0/DederProject.pkl"

import "../../resources/ProtobufPlugin.pkl" as PB

plugins {
  new PB.ProtobufPlugin {
    config = new {
      defaults = new  {
        builtins {
          new  {
            name = "java"
          }
        }
        plugins {
          new {
            name = "grpc-java"
            resolver = new {
              kind = "binary-maven"
              dependency = "io.grpc:protoc-gen-grpc-java:1.75.0"
            }
          }
        }
      }
    }
  }
}

modules {
  new ScalaModule {
    id = "consumer"
    root = "."
    scalaVersion = "3.7.4"
    deps {
      "com.google.protobuf:protobuf-java:4.31.1"
      "io.grpc:grpc-api:1.75.0"
      "io.grpc:grpc-protobuf:1.75.0"
      "io.grpc:grpc-stub:1.75.0"
      "javax.annotation:javax.annotation-api:1.3.2"
    }
    mainClass = "example.greeter.Main"
  }
}
