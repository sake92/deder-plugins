    }
  }
}

local const m1 = new ScalaModule {
  id = "example"
  root = "."
  scalaVersion = "3.7.4"
  mainClass = "example.main"
}

local const m2 = new ScalaModule {
  id = "m2"
  root = "m2"
  scalaVersion = "3.7.4"
  moduleDeps { m1 }
}

modules {
  m1
  m2
}
