amends "https://sake92.github.io/deder/config/early-access/DederProject.pkl"

import "../../resources/WebDashboardPlugin.pkl" as WD

/*
tools {
  ["tui"] {
    deps {
      "ba.sake::deder-tui-dashboard:0.3.1-SNAPSHOT"
