amends "https://sake92.github.io/deder/config/v0.17.0/DederProject.pkl"

import "../../resources/WebDashboardPlugin.pkl" as WD

plugins {
  new WD.WebDashboardPlugin {
    config = new {
      enabled = true
      statsRefreshIntervalMs = 1000
    }
  }
}

local const m1 = new ScalaModule {
  id = "example"
  root = "."
  scalaVersion = "3.7.4"
  mainClass = "example.main"
  mvnApps {
    ["tui"] = new MvnApp {
      deps  {
        "ba.sake::deder-tui-dashboard:0.2.1-SNAPSHOT"
      }
      mainClass = "ba.sake.deder.tuidashboard.app.TuiDashboardMain"
    }
  }
}

local const m2 = new ScalaModule {
  id = "m2"
  root = "m2"
  scalaVersion = "3.7.4"
  moduleDeps { m1 }
}

modules {
  m1
  m2
}
