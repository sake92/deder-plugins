amends "https://sake92.github.io/deder/config/early-access/DederProject.pkl"

import "../../resources/WebDashboardPlugin.pkl" as WD

plugins {
  new WD.WebDashboardPlugin {
    config = new {
      enabled = true
    }
  }
}

modules {
  new ScalaModule {
    id = "example"
    root = "."
    scalaVersion = "3.7.4"
    mainClass = "example.main"
  }
}
