amends "https://sake92.github.io/deder/config/v0.9.1/DederProject.pkl"

import "../../resources/WebDashboardPlugin.pkl" as WD

plugins {
  new WD.WebDashboardPlugin {
    config = new WD.WebDashboardPluginConfig {
      port = 9090
    }
  }
}

modules {
  new ScalaModule {
    id = "example"
    root = "."
    scalaVersion = "3.7.4"
    mainClass = "example.main"
  }
}
