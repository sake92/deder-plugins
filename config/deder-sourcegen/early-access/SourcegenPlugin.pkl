module ba.sake.deder.plugins.sourcegen

import "https://sake92.github.io/deder/config-api/DederPlugins.pkl" as P

class SourcegenPlugin extends P.DederPlugin {
  id = "sourcegen"
  version: String = "0.6.1-SNAPSHOT"
  deps {
    "ba.sake::deder-sourcegen:\(version)"
  }
  config: SourcegenPluginConfig = new {}
}

class SourcegenPluginConfig {
  defaults: ModuleDefaults = new {}
  modules: Mapping<String, ModuleOverride> = new Mapping {}
}

class ModuleDefaults {
  enabled: Boolean = true
  deps: Listing<String> = new {}
  scriptsDir: String = "deder/sourcegen"
  scalaVersion: String? = null
  outputSourceSet: String = "main"
  extra: Mapping<String, String> = new Mapping {}
}

class ModuleOverride {
  enabled: Boolean? = null
  deps: Listing<String>? = null
  scriptsDir: String? = null
  scalaVersion: String? = null
  outputSourceSet: String? = null
  extra: Mapping<String, String>? = null
}

config: SourcegenPluginConfig = new {}
