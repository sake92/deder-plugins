amends "https://sake92.github.io/deder/config/v0.19.5/DederProject.pkl"

local const scalaVer = "3.7.4"
local const pluginApiVersion = "0.19.6-SNAPSHOT"

local const function pom(artId: String, artName: String, artDesc: String): PomSettings = new {
  groupId = "ba.sake"
  artifactId = artId
  name = artName
  description = artDesc
  url = "https://github.com/sake92/deder-plugins"
  licenses {
    new PomLicense {
      name = "Apache 2.0 License"
      url = "https://opensource.org/license/apache-2-0"
    }
  }
  developers {
    new PomDeveloper {
      id = "sake92"
      name = "Sakib Hadžiavdić"
      email = "sake92@sake.ba"
    }
  }
  scm {
    url = "https://github.com/sake92/deder-plugins"
    connection = "scm:git:git://github.com/sake92/deder-plugins.git"
  }
}

local const pluginModules =
  new CreateScalaModules {
    root = "deder-protobuf"
    id = "deder-protobuf"
    layout = "default"
    template = new ScalaModule {
      scalaVersion = scalaVer
      deps {
        "ba.sake::deder-plugin-api:\(pluginApiVersion)"
      }
      pomSettings =
        pom(
          "deder-protobuf",
          "Deder Protobuf Plugin",
          "Deder plugin for protobuf and gRPC code generation",
        )
      publish = true
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

local const buildInfoModules =
  new CreateScalaModules {
    root = "deder-build-info"
    id = "deder-build-info"
    layout = "default"
    template = new ScalaModule {
      scalaVersion = scalaVer
      deps {
        "ba.sake::deder-plugin-api:\(pluginApiVersion)"
      }
      pomSettings =
        pom(
          "deder-build-info",
          "Deder BuildInfo Plugin",
          "Deder plugin that generates a BuildInfo Scala object with build metadata constants",
        )
      publish = true
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

local const dashboardModules =
  new CreateScalaModules {
    root = "deder-web-dashboard"
    id = "deder-web-dashboard"
    layout = "default"
    template = new ScalaModule {
      scalaVersion = scalaVer
      scalacOptions { "-Yretain-trees" }
      deps {
        "ba.sake::deder-plugin-api:\(pluginApiVersion)"
        "ba.sake::sharaf-jdk-httpserver:0.19.0"
      }
      pomSettings =
        pom(
          "deder-web-dashboard",
          "Deder Web Dashboard Plugin",
          "Deder plugin that starts a web dashboard showing module info and live server stats",
        )
      publish = true
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

local const tuiModules =
  new CreateScalaModules {
    root = "deder-tui-dashboard"
    id = "deder-tui-dashboard"
    layout = "default"
    template = new ScalaModule {
      scalaVersion = scalaVer
      deps {
        "ba.sake::tupson:0.20.0"
        "xyz.matthieucourt::layoutz:0.7.0"
      }
      mainClass = "ba.sake.deder.tuidashboard.app.TuiDashboardMain"
      pomSettings =
        pom(
          "deder-tui-dashboard",
          "Deder TUI Dashboard",
          "CLI TUI dashboard for Deder live build stats"
        )
      publish = true
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

modules {
  ...pluginModules.all
  ...buildInfoModules.all
  ...dashboardModules.all
  ...tuiModules.all
}
